# Copy to .env (gitignored) and fill in. Only the CLI coach needs these  - 
# everything else in this repo works without any key.
#
# Any OpenAI-compatible endpoint works. The defaults point at OpenRouter,
# where the default model is FREE - a $0 key from openrouter.ai is enough.
YF_COACH_API_KEY=
YF_COACH_BASE_URL=https://openrouter.ai/api/v1
YF_COACH_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
