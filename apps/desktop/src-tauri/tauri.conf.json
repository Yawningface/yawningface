{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "yawningface",
  "version": "0.2.7",
  "identifier": "org.yawningface.block.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1601",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "yawningface",
        "width": 960,
        "height": 700,
        "minWidth": 720,
        "minHeight": 560,
        "center": true,
        "resizable": true,
        "visible": false,
        "theme": "Light"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
