{
  "manifest_version": 3,
  "name": "yawningface",
  "version": "0.1.0",
  "description": "The sites that eat your day, gone. One click, feeds off, in this browser.",
  "minimum_chrome_version": "120",
  "action": {
    "default_popup": "popup.html",
    "default_title": "yawningface"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_page": "options.html",
  "permissions": [
    "storage",
    "alarms",
    "declarativeNetRequest",
    "tabs"
  ],
  "host_permissions": ["<all_urls>"],
  "web_accessible_resources": [
    {
      "resources": ["blocked.html", "art/*", "fonts/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
