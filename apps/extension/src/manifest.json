{
  "manifest_version": 3,
  "name": "yawningface",
  "version": "0.1.5",
  "description": "Browser companion for yawningface desktop: custom block pages, Insights events, and reason-gated exceptions.",
  "minimum_chrome_version": "120",
  "key": "",
  "action": {
    "default_popup": "popup.html",
    "default_title": "yawningface"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_page": "options.html",
  "permissions": [
    "storage",
    "alarms",
    "declarativeNetRequest",
    "nativeMessaging"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "blocked.html",
        "art/*",
        "fonts/*"
      ],
      "matches": [
        "http://*/*",
        "https://*/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
