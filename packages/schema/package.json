{
  "name": "@yawningface/schema",
  "version": "0.1.0",
  "description": "The YawningFace cross-device contract: one config document, evaluated identically on every client.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema.json": "./schema.json"
  },
  "files": [
    "dist",
    "schema.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test test/schema.test.mjs"
  }
}
